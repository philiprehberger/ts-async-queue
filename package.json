{
  "name": "@philiprehberger/async-queue",
  "version": "0.1.7",
  "description": "Priority queue for async tasks with concurrency control",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "queue",
    "async",
    "concurrency",
    "priority",
    "rate-limit",
    "pool"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-async-queue.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-async-queue#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-async-queue/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
